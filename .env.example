# Shape Rotator Matrix deployment — environment vars.
#
# Do NOT commit the real .env. The real file is produced by
# ./deploy/encode_env.sh which reads plaintext from landing/ + knock-approver/,
# merges with the secrets below, and writes .env (gitignored).

# --- DNS-01 for Let's Encrypt ---
NAMECHEAP_USERNAME=
NAMECHEAP_API_KEY=

# --- Continuwuity ---
# Rotate any time; old one is invalidated when redeployed.
REGISTRATION_TOKEN=

# --- dstack CVM ---
# The ed25519 pubkey of whoever can `phala ssh` into the CVM.
DSTACK_AUTHORIZED_KEYS=

# --- Knock-approver ---
# Access token of a Matrix user with PL >= 50 in the space.
KNOCK_APPROVER_TOKEN=
# Short form (no :server suffix) works with continuwuity.
SHAPEROTATOR_SPACE_ID=!4FL8uL5OEYLATG1VH4wC2CD3pfIV6BMFId9VT7rmm-g

# Comma-separated child room IDs (unsuffixed) that signups should auto-join
# via the space's "restricted" rule. Typically general + announcements + bot-noise.
SPACE_CHILD_IDS=

# MXID that freshly-signed-up users DM with an intro line. Per-code override:
# set "inviter" on a signup_codes.json entry.
ONBOARDING_INVITER_MXID=@socrates1024:matrix.org
# JSON map of {code: {uses_remaining, label}} seeded on first start.
# Safe to change — on restart, only codes not yet present are added.
INITIAL_CODES={}

# Same format, different set: codes that unlock *account creation* on this
# server via POST /signup/api (consumed by the landing page form at /signup).
# Keep these more tightly controlled — each successful signup creates a new
# durable identity on the server.
INITIAL_SIGNUP_CODES={}

# --- Admin command surface (issue #7) ---
# Room the bot listens in for !mint / !codes / !revoke commands. The space
# room itself is cleartext, so it works for v1; switch to a dedicated
# cleartext admin room or move to mautrix when you want commands in an
# encrypted room.
ADMIN_COMMAND_ROOM=
# Power-level threshold to use admin commands (default 50). Anyone with PL
# >= this in ADMIN_COMMAND_ROOM may run !mint etc.
ADMIN_PL_THRESHOLD=50
# Comma-separated mxids permitted regardless of PL — useful to delegate
# admin without bumping space PLs. Example: @socrates1024:matrix.org,@helper:matrix.org
ADMIN_ALLOWLIST=

# --- Auto-populated by deploy/encode_env.sh (leave blank) ---
INDEX_B64=
JOIN_B64=
SIGNUP_B64=
NGINX_CONF_B64=
APPROVER_B64=
